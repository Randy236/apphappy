# Copia estas variables en Render → Environment (Web Service happy-jump-api)
# MySQL gratis: https://www.db4free.net

NODE_ENV=production
JWT_SECRET=cambia-por-un-secreto-largo-unico

DB_HOST=db4free.net
DB_PORT=3306
DB_USER=tu_usuario_db4free
DB_PASSWORD=tu_password_db4free
DB_NAME=happy_jump
DB_SSL=false

