{
  "name": "happy-jump-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:railway": "node scripts/init-railway-db.mjs && node src/index.js",
    "start:cloud": "node scripts/init-railway-db.mjs && node src/index.js",
    "start:render": "npm run start:cloud",
    "db:init": "node scripts/init-railway-db.mjs",
    "dev": "node --watch src/index.js",
    "migrate:004": "node scripts/apply-migration-004.mjs",
    "migrate:005": "node scripts/apply-migration-005.mjs",
    "migrate:008": "node scripts/apply-migration-008.mjs",
    "migrate:009": "node scripts/apply-migration-009.mjs",
    "migrate:010": "node scripts/apply-migration-010.mjs",
    "demo:reset-ventas": "node scripts/apply-cleanup-ventas-y-sesiones.mjs",
    "cleanup:ventas-y-sesiones": "node scripts/apply-cleanup-ventas-y-sesiones.mjs",
    "test": "node --test test/*.test.mjs",
    "test:junit": "node --test --test-reporter=junit --test-reporter-destination=../app/build/test-results/apiUnit/TEST-api.xml test/*.test.mjs",
    "test:allure": "npm run test:junit",
    "test:ci": "node --test test/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=src/domain/** --test test/*.test.mjs",
    "coverage:verify": "node scripts/verify-domain-coverage.mjs",
    "k6:verify": "node scripts/verify-k6-coverage.mjs",
    "k6:prepare": "node scripts/clear-sessions-for-k6.mjs",
    "soft-delete:verify": "node scripts/verify-soft-delete.mjs",
    "auditoria:verify": "node scripts/verify-auditoria.mjs",
    "usuario:crear": "node scripts/crear-usuario.mjs",
    "usuarios:prueba": "node scripts/crear-usuarios-prueba.mjs",
    "migrate:011": "node scripts/apply-migration-011.mjs",
    "swagger:verify": "node scripts/verify-swagger-coverage.mjs",
    "k6:api": "node scripts/k6-api.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "swagger-ui-express": "^5.0.1"
  }
}
