# Normalizar texto a UTF-8 + LF (evita warning de encoding en SonarCloud/CI)
* text=auto eol=lf

*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.gradle text eol=lf
*.sh text eol=lf
Jenkinsfile text eol=lf

gradlew text eol=lf
*.bat text eol=crlf

# Binarios / lockfiles (no re-normalizar)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.lockfile binary
