        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombreCliente\": \"Juan Pérez\",\n  \"deporte\": \"Futbol\",\n  \"fecha\": \"15-06-2030\",\n  \"hora\": \"10:00:00\",\n  \"montoTotal\": 50,\n  \"adelanto\": 20\n}"
        },
        "url": "{{baseUrl}}/reservas-cancha"
