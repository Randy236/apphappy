{
  "info": {
    "_postman_id": "happy-jump-validaciones",
    "name": "Happy Jump API — Validación de parámetros",
    "description": "Pruebas integrales Postman: entradas inválidas deben responder HTTP 400.\n\nUsuarios seed: Admin / Rosisela — PIN 1234\n\nEjecutar con Collection Runner (orden secuencial). API en https://happyjump.sorbits.site",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://happyjump.sorbits.site" },
    { "key": "tokenAdmin", "value": "" },
    { "key": "tokenWorker", "value": "" },
    { "key": "workerId", "value": "2" }
  ],
  "item": [
    {
      "name": "VAL-001 Login nombre con números",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin123\",\n  \"pin\": \"1234\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-001: 400 nombre con números', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-002 Login PIN con letras",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"12ab\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-002: 400 PIN con letras', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-003 Login PIN más de 5 dígitos",
      "request": {
        "method": "POST",
