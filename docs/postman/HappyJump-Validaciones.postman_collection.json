          "mode": "raw",
          "raw": "{\n  \"nombreCliente\": \"María López\",\n  \"tipoEvento\": \"Cumpleanos\",\n  \"zona\": \"Zona A\",\n  \"numeroNinos\": 15,\n  \"horaInicio\": \"14:00:00\",\n  \"horaFin\": \"16:00:00\",\n  \"precioTotal\": 300,\n  \"adelanto\": 100,\n  \"salon\": \"Salón Principal\",\n  \"fecha\": \"2030-06-20\"\n}"
        },
