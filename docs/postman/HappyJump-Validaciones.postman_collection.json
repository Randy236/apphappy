        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombreCliente\": \"Juan Pérez\",\n  \"deporte\": \"Futbol\",\n  \"fecha\": \"2030-06-15\",\n  \"hora\": \"10:00:00\",\n  \"montoTotal\": 50,\n  \"adelanto\": 80\n}"
        },
        "url": "{{baseUrl}}/reservas-cancha"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-009: 400 adelanto', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "Logout Admin (setup worker)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
        "url": "{{baseUrl}}/auth/logout"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('Logout 200', () => pm.response.to.have.status(200));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "Login Worker (setup)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Rosisela\",\n  \"pin\": \"1234\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Login worker 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('tokenWorker', j.token);",
            "pm.collectionVariables.set('workerId', String(j.usuario.id));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-010 Salón inválido",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenWorker}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombreCliente\": \"María López\",\n  \"tipoEvento\": \"Otro\",\n  \"zona\": \"Zona A\",\n  \"numeroNinos\": 10,\n  \"horaInicio\": \"14:00:00\",\n  \"horaFin\": \"16:00:00\",\n  \"precioTotal\": 200,\n  \"adelanto\": 50,\n  \"salon\": \"Salón Falso\",\n  \"fecha\": \"2030-06-20\"\n}"
        },
        "url": "{{baseUrl}}/reservas-salones"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-010: 400 salón', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-011 PIN nuevo más de 5 dígitos",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenWorker}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pinActual\": \"1234\",\n  \"pinNuevo\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/usuarios/{{workerId}}/pin"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-011: 400 PIN nuevo largo', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
