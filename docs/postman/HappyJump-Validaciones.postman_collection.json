        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-003: 400 PIN largo', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-004 Login PIN corto",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-004: 400 PIN corto', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "Login Admin (setup)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"1234\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Login admin 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenAdmin', pm.response.json().token);"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-005 Reportes periodo inválido",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
        "url": "{{baseUrl}}/reportes?periodo=anual"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-005: 400 periodo', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-006 Cancha deporte inválido",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombreCliente\": \"Juan Pérez\",\n  \"deporte\": \"Tenis\",\n  \"fecha\": \"2030-06-15\",\n  \"hora\": \"10:00:00\",\n  \"montoTotal\": 50,\n  \"adelanto\": 20\n}"
        },
        "url": "{{baseUrl}}/reservas-cancha"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('VAL-006: 400 deporte', () => pm.response.to.have.status(400));"],
          "type": "text/javascript"
        }
      }]
    },
