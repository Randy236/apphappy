{
  "info": {
    "_postman_id": "happy-jump-api-integration",
    "name": "Happy Jump API — Pruebas integrales",
    "description": "Pruebas de integración API + MySQL. Ejecutar con Collection Runner.\n\nUsuarios: Admin / Rosisela — PIN 1234",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "reservaCanchaId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Sistema (sin auth)",
      "item": [
        {
          "name": "CP-006 GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ok true', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.ok).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /hello (k6)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/hello"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Good Morning', () => pm.expect(pm.response.text()).to.include('Good Morning'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /sumar (k6)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sumar?a=5&b=3"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Resultado 8', () => pm.expect(pm.response.text()).to.eql('8'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Autenticación",
      "item": [
        {
          "name": "CP-002 Login Admin (guarda token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Token JWT', () => pm.expect(j.token).to.be.a('string').and.not.empty);",
                  "pm.test('Rol administrador', () => pm.expect(j.usuario.rol).to.eql('administrador'));",
                  "pm.collectionVariables.set('token', j.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "CP-001 Login Trabajador Rosisela",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Rosisela\",\n  \"pin\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Rol trabajador', () => pm.expect(j.usuario.rol).to.eql('trabajador'));",
                  "pm.collectionVariables.set('token', j.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "CP-003 Login credenciales incorrectas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"9999\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Reservas Cancha (integración API+BD)",
      "item": [
        {
          "name": "Login Admin (precondición)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"pin\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "CP-007 GET reservas-cancha",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservas-cancha?desde=2026-01-01&hasta=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["reservas-cancha"],
              "query": [
                { "key": "desde", "value": "2026-01-01" },
                { "key": "hasta", "value": "2026-12-31" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Array JSON', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "CP-008 POST crear reserva cancha",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const d = new Date();",
                  "d.setDate(d.getDate() + 7);",
                  "const pad = (n) => String(n).padStart(2, '0');",
                  "const fecha = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;",
                  "pm.collectionVariables.set('fechaReserva', fecha);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('Tiene id', () => pm.expect(j.id).to.be.a('number');",
                  "pm.collectionVariables.set('reservaCanchaId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreCliente\": \"Cliente Postman Integración\",\n  \"deporte\": \"Futbol\",\n  \"fecha\": \"{{fechaReserva}}\",\n  \"hora\": \"10:00:00\",\n  \"montoTotal\": 50,\n  \"adelanto\": 20\n}"
            },
            "url": "{{baseUrl}}/reservas-cancha"
          }
        }
      ]
    },
