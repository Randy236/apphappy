# UTF-8 + LF en todo el repo (SonarCloud + CI Linux)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts,java,xml,properties,gradle}]
charset = utf-8
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[gradlew]
end_of_line = lf

[*.bat]
end_of_line = crlf
